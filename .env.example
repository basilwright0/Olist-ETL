# Copy to .env before running `docker compose up`.

# Analytics warehouse (Postgres) — used by both dbt and the extract tasks.
WAREHOUSE_HOST=warehouse
WAREHOUSE_PORT=5432
WAREHOUSE_USER=warehouse
WAREHOUSE_PASSWORD=warehouse
WAREHOUSE_DB=warehouse
WAREHOUSE_SCHEMA=analytics
RAW_SCHEMA=raw

# On Linux set this to your host UID (run: id -u) so Airflow file permissions
# line up. On Windows/macOS Docker Desktop the default is fine.
AIRFLOW_UID=50000
